# ═══════════════════════════════════════════════════════════
# ImpactAI — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Groq Cloud API Key (REQUIRED for AI chat) ─────────────
# Get yours free at https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# ── JWT Authentication ─────────────────────────────────────
JWT_SECRET=impactai_jwt_secret_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── CORS (comma‑separated origins) ────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:5000,http://localhost:3000

# ── Google OAuth (optional) ────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
